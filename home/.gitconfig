# Managed by ~/dotfiles (GNU stow)
[user]
	name = Jake Shoemaker
	email = jakeshoe3@gmail.com

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rerere]
	enabled = true

[color]
	ui = auto

[core]
	editor = vim
	excludesfile = ~/.gitignore_global
